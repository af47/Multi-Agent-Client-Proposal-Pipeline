# ──────────────────────────────────────────────────────────────────────────────
# Client Proposal Pipeline — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED: Your Anthropic API key
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Smart Model Routing ───────────────────────────────────────────────────────
# The pipeline uses TWO models to balance cost and capability:
#
#   SONNET  → Heavy reasoning tasks (Debrief, Proposal, Critique)
#   HAIKU   → Lightweight tasks (feedback translation, schema fix-up retries)
#
# Expected savings: ~35–45% vs. using Sonnet for every call.

# Model for heavy tasks: matrix extraction, proposal generation, scoring
# SONNET_MODEL=claude-sonnet-4-5-20250929

# Model for lightweight tasks: feedback classification, JSON retries
# HAIKU_MODEL=claude-haiku-4-5-20251001

# ── Optional overrides ────────────────────────────────────────────────────────

# Maximum output tokens per Claude call (default: 8192)
# MAX_TOKENS=8192

# Maximum pipeline iterations before auto-stop (default: 5)
# MAX_ITERATIONS=5
